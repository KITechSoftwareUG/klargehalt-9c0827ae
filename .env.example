# ============================================================================
# KlarGehalt — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================================

# ============================================================================
# Logto Authentication
# Get these from: https://auth.klargehalt.de (Logto admin panel)
# ============================================================================

LOGTO_ENDPOINT=https://auth.klargehalt.de
LOGTO_APP_ID=
LOGTO_APP_SECRET=
LOGTO_COOKIE_SECRET=                     # random 32+ char string: openssl rand -hex 32

# Logto M2M app (used to create orgs via Management API on signup)
LOGTO_M2M_APP_ID=
LOGTO_M2M_APP_SECRET=
LOGTO_MANAGEMENT_API_RESOURCE=https://auth.klargehalt.de/api

# Logto webhook signing keys
# Each webhook in Logto has its own auto-generated signing key
LOGTO_WEBHOOK_SECRET=
LOGTO_WEBHOOK_SIGNING_KEY_1=
LOGTO_WEBHOOK_SIGNING_KEY_2=

# ============================================================================
# Application URLs
# Production:  APP_BASE_URL=https://app.klargehalt.de
# Staging:     APP_BASE_URL=https://staging.app.klargehalt.de
# ============================================================================

APP_BASE_URL=https://app.klargehalt.de
NEXT_PUBLIC_APP_URL=https://app.klargehalt.de
NEXT_PUBLIC_ROOT_DOMAIN=klargehalt.de

# ============================================================================
# Supabase
# Get these from: Supabase Dashboard → Settings → API
# Production project ref: btbucjkczpejplykyvkj
# ============================================================================

NEXT_PUBLIC_SUPABASE_URL=https://btbucjkczpejplykyvkj.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================================
# Stripe
# Production: use sk_live_* / pk_live_* keys
# Staging:    use sk_test_* / pk_test_* keys
# ============================================================================

STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (copy from Stripe Dashboard → Products)
STRIPE_PRICE_BASIS_MONTHLY=
STRIPE_PRICE_BASIS_YEARLY=
STRIPE_PRICE_PROFESSIONAL_MONTHLY=
STRIPE_PRICE_PROFESSIONAL_YEARLY=

# ============================================================================
# Email (Resend)
# Get from: https://resend.com/api-keys
# ============================================================================

RESEND_API_KEY=re_...

# ============================================================================
# AI (Google Gemini — for pay equity explanations)
# Get from: https://aistudio.google.com/app/apikey
# ============================================================================

GOOGLE_GEMINI_API_KEY=

# ============================================================================
# Cron jobs
# Any random secret — used to authenticate /api/cron/* endpoints
# ============================================================================

CRON_SECRET=                             # openssl rand -hex 32

# ============================================================================
# Error tracking (Sentry)
# Set automatically by Sentry CLI during build — do not set manually
# ============================================================================

# SENTRY_AUTH_TOKEN=

# ============================================================================
# Analytics (Plausible — optional)
# ============================================================================

# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=klargehalt.de
# NEXT_PUBLIC_PLAUSIBLE_SCRIPT_URL=https://plausible.io/js/script.js

# Super-admin Logto user ID
SUPER_ADMIN_USER_ID=your_logto_user_id_here
